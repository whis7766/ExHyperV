<UserControl x:Class="ExHyperV.Views.Components.VmAddGpuProgressView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:vm="clr-namespace:ExHyperV.ViewModels"
             xmlns:models="clr-namespace:ExHyperV.Models"
             xmlns:converters="clr-namespace:ExHyperV.Converters"
             xmlns:properties="clr-namespace:ExHyperV.Properties"
             mc:Ignorable="d" 
             d:DesignHeight="850" d:DesignWidth="1000"
             UseLayoutRounding="True"
             d:DataContext="{d:DesignInstance vm:VirtualMachinesPageViewModel}">

    <UserControl.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BoolToVis" />
    </UserControl.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 1. 顶部标题栏 -->
        <Grid Grid.Row="0" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Text="{x:Static properties:Resources.Label_Progress}" FontSize="20" VerticalAlignment="Center" 
                       Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}"/>

            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <!-- ✅ 重置/重试按钮：随时重置整个流程 -->
                <ui:Button Appearance="Transparent" Padding="8" Margin="0,0,4,0"
                           ToolTip="{x:Static properties:Resources.VmAddGpuProgressView_1}"
                           Command="{Binding ResetGpuDeploymentCommand}">
                    <ui:SymbolIcon Symbol="ArrowCounterclockwise24" FontSize="18" Foreground="{ui:ThemeResource SystemAccentColorPrimaryBrush}"/>
                </ui:Button>

                <ui:Button Appearance="Transparent" Padding="8" Command="{Binding CancelAddGpuCommand}">
                    <ui:SymbolIcon Symbol="ArrowLeft24" FontSize="18"/>
                </ui:Button>
            </StackPanel>
        </Grid>

        <!-- 2. 主滚动区域 -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="0,0,12,0">

                <!-- ✅ 交互层：分区选择/SSH 面板 -->
                <ui:Card Margin="0,0,0,24" Padding="0" 
                         Visibility="{Binding ShowPartitionSelector, Converter={StaticResource BoolToVis}}">
                    <Grid>
                        <!-- 1. 分区列表界面 -->
                        <Grid x:Name="PartitionListGrid">
                            <Grid.Style>
                                <Style TargetType="Grid">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ShowSshForm}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Grid.Style>

                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <Border Padding="16,12" Background="{ui:ThemeResource ControlFillColorTertiaryBrush}" CornerRadius="8,8,0,0">
                                <TextBlock Text="{x:Static properties:Resources.Label_SelectPart}" FontSize="14" Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}"/>
                            </Border>

                            <ui:ListView Grid.Row="1" 
                                         ItemsSource="{Binding DetectedPartitions}" 
                                         SelectedItem="{Binding SelectedPartition}" 
                                         Padding="8">
                                <ui:ListView.ItemTemplate>
                                    <DataTemplate DataType="{x:Type models:PartitionInfo}">
                                        <Grid Margin="4,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="48"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Image Source="{Binding IconPath}" Width="24" Height="24" RenderOptions.BitmapScalingMode="HighQuality"/>
                                            <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding DisplayName}" FontSize="14" Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}"/>
                                                <TextBlock Text="{Binding TypeDescription}" FontSize="12" Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}"/>
                                            </StackPanel>
                                        </Grid>
                                    </DataTemplate>
                                </ui:ListView.ItemTemplate>
                            </ui:ListView>
                        </Grid>

                    </Grid>
                </ui:Card>

                <!-- 任务清单 (保持不变) -->
                <ItemsControl ItemsSource="{Binding GpuTasks}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type models:TaskItem}">
                            <Border x:Name="TaskBorder" Margin="0,0,0,8" Padding="16,12" CornerRadius="8" 
                                    Background="{ui:ThemeResource ControlFillColorDefaultBrush}" 
                                    BorderBrush="{ui:ThemeResource CardStrokeColorDefaultBrush}" 
                                    BorderThickness="1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="42"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <Grid Grid.Column="0" VerticalAlignment="Center" HorizontalAlignment="Left">
                                        <ui:FontIcon x:Name="IconPending" Glyph="&#xEA3A;" FontSize="18" FontFamily="{DynamicResource SegoeFluentIcons}" Foreground="{ui:ThemeResource TextFillColorDisabledBrush}" Visibility="Collapsed"/>
                                        <ui:ProgressRing x:Name="IconRunning" IsIndeterminate="True" Width="18" Height="18" Visibility="Collapsed"/>
                                        <ui:FontIcon x:Name="IconSuccess" Glyph="&#xEC61;" FontSize="20" FontFamily="{DynamicResource SegoeFluentIcons}" Foreground="#FF008A17" Visibility="Collapsed"/>
                                        <ui:FontIcon x:Name="IconFailed" Glyph="&#xEB90;" FontSize="20" FontFamily="{DynamicResource SegoeFluentIcons}" Foreground="Red" Visibility="Collapsed"/>
                                    </Grid>

                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="2,0,0,0">
                                        <TextBlock x:Name="NameTxt" Text="{Binding Name}" FontSize="15" Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}"/>
                                        <TextBlock x:Name="DescTxt" Text="{Binding Description}" FontSize="12" Margin="0,4,0,0" TextWrapping="Wrap" Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}"/>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <DataTemplate.Triggers>
                                <DataTrigger Binding="{Binding Status}" Value="Pending">
                                    <Setter TargetName="IconPending" Property="Visibility" Value="Visible"/>
                                    <Setter TargetName="NameTxt" Property="Foreground" Value="{ui:ThemeResource TextFillColorDisabledBrush}"/>
                                    <Setter TargetName="DescTxt" Property="Foreground" Value="{ui:ThemeResource TextFillColorDisabledBrush}"/>
                                    <Setter TargetName="TaskBorder" Property="Opacity" Value="0.6"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Status}" Value="Running">
                                    <Setter TargetName="IconRunning" Property="Visibility" Value="Visible"/>
                                    <Setter TargetName="TaskBorder" Property="Background" Value="{ui:ThemeResource ControlFillColorSecondaryBrush}"/>
                                    <Setter TargetName="TaskBorder" Property="BorderBrush" Value="{ui:ThemeResource ControlStrongFillColorDefaultBrush}"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Status}" Value="Success">
                                    <Setter TargetName="IconSuccess" Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Status}" Value="Failed">
                                    <Setter TargetName="IconFailed" Property="Visibility" Value="Visible"/>
                                    <Setter TargetName="DescTxt" Property="Foreground" Value="#C42B1C"/>
                                </DataTrigger>
                            </DataTemplate.Triggers>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>


                <!-- 3. 配置日志控制台 (保持不变) -->
                <ui:Card Margin="0,16,0,0" Padding="0" VerticalAlignment="Stretch"
                         Visibility="{Binding ShowLogConsole, Converter={StaticResource BoolToVis}}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="250"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" Padding="12,8" Background="{ui:ThemeResource ControlFillColorTertiaryBrush}" CornerRadius="8,8,0,0">
                            <Grid>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <ui:SymbolIcon Symbol="Document24" Margin="0,0,8,0" Filled="True"/>
                                    <TextBlock Text="{x:Static properties:Resources.Label_ConfigLog}" FontWeight="Medium" VerticalAlignment="Center" Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}"/>
                                </StackPanel>
                                <ui:Button Content="{x:Static properties:Resources.Button_CopyLog}" Icon="Copy24" Appearance="Transparent" HorizontalAlignment="Right" Padding="8,4" Command="{Binding CopyLogCommand}"/>
                            </Grid>
                        </Border>

                        <Border Grid.Row="1" Background="#0C0C0C" CornerRadius="0,0,8,8">
                            <TextBox x:Name="LogTextBox" 
                                     Text="{Binding GpuDeploymentLog, Mode=OneWay}"
                                     IsReadOnly="True"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     Style="{x:Null}"
                                     Background="#0C0C0C"
                                     Foreground="#D0D0D0"
                                     BorderThickness="0"
                                     FontFamily="Consolas, Monospace"
                                     FontSize="12"
                                     Padding="12"
                                     VerticalScrollBarVisibility="Auto"
                                     TextChanged="LogTextBox_TextChanged">
                            </TextBox>
                        </Border>
                    </Grid>
                </ui:Card>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>