<UserControl
    x:Class="ExHyperV.Views.Components.VmAddStorageView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="clr-namespace:ExHyperV.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:properties="clr-namespace:ExHyperV.Properties"
    xmlns:system="clr-namespace:System;assembly=mscorlib"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:vm="clr-namespace:ExHyperV.ViewModels"
    d:DataContext="{d:DesignInstance vm:VirtualMachinesPageViewModel}"
    d:DesignHeight="800"
    d:DesignWidth="800"
    mc:Ignorable="d">

    <UserControl.Resources>
        <converters:EqualityConverter x:Key="EqualityConverter" />
        <converters:InverseBooleanConverter x:Key="InverseBooleanConverter" />
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <converters:EqualityToVisibilityConverter x:Key="EqualityToVisibilityConverter" />

        <Style BasedOn="{StaticResource {x:Type ui:ToggleSwitch}}" TargetType="ui:ToggleSwitch">
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!--  顶部标题栏  -->
        <Grid Grid.Row="0" Margin="24,24,24,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock
                VerticalAlignment="Center"
                FontSize="24"
                FontWeight="SemiBold"
                Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}"
                Text="{x:Static properties:Resources.AddDisk_WindowTitle}" />

            <ui:Button
                Grid.Column="1"
                Padding="8"
                Appearance="Transparent"
                Command="{Binding GoBackCommand}"
                Icon="{ui:SymbolIcon Symbol=ArrowLeft24}" />
        </Grid>

        <ScrollViewer
            Grid.Row="1"
            Padding="24,0,24,24"
            VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <!--  插槽配置  -->
                <TextBlock
                    Margin="0,0,0,8"
                    FontSize="14"
                    Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}"
                    Text="{x:Static properties:Resources.AddDisk_SlotConfig}" />

                <Border
                    Margin="0,0,0,8"
                    Padding="16"
                    Background="{ui:ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ui:ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <!--  左侧：标题  -->


                        <!--  中间：三个下拉列表及标签  -->
                        <Grid
                            Grid.Column="0"
                            Margin="8,0"
                            IsEnabled="{Binding AutoAssign, Converter={StaticResource InverseBooleanConverter}}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <!--  接口  -->
                            <TextBlock
                                Grid.Column="0"
                                Margin="0,0,8,0"
                                VerticalAlignment="Center"
                                FontSize="12"
                                Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}"
                                Text="{x:Static properties:Resources.AddDisk_Interface}" />
                            <ComboBox
                                Grid.Column="1"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Center"
                                ItemsSource="{Binding AvailableControllerTypes}"
                                SelectedItem="{Binding SelectedControllerType}" />

                            <!--  编号  -->
                            <TextBlock
                                Grid.Column="3"
                                Margin="0,0,8,0"
                                VerticalAlignment="Center"
                                FontSize="12"
                                Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}"
                                Text="{x:Static properties:Resources.AddDisk_Number}" />
                            <ComboBox
                                Grid.Column="4"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Center"
                                ItemsSource="{Binding AvailableControllerNumbers}"
                                SelectedItem="{Binding SelectedControllerNumber}" />

                            <!--  位置  -->
                            <TextBlock
                                Grid.Column="6"
                                Margin="0,0,8,0"
                                VerticalAlignment="Center"
                                FontSize="12"
                                Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}"
                                Text="{x:Static properties:Resources.AddDisk_Location}" />
                            <ComboBox
                                Grid.Column="7"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Center"
                                ItemsSource="{Binding AvailableLocations}"
                                SelectedItem="{Binding SelectedLocation, Mode=TwoWay}" />
                        </Grid>

                        <StackPanel
                            Grid.Column="1"
                            Margin="16,0,0,0"
                            VerticalAlignment="Center">
                            <TextBlock
                                FontSize="14"
                                Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}"
                                Text="{x:Static properties:Resources.AddDisk_AutoAssign}" />
                        </StackPanel>

                        <!--  右侧：开关  -->
                        <ui:ToggleSwitch
                            Grid.Column="2"
                            Margin="4,0,0,0"
                            VerticalAlignment="Center"
                            IsChecked="{Binding AutoAssign}" />
                    </Grid>
                </Border>
                <!--  媒体设置  -->
                <TextBlock
                    Margin="0,0,0,8"
                    FontSize="14"
                    Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}"
                    Text="{x:Static properties:Resources.Label_MediaSettings}" />

                <Border
                    Padding="16"
                    Background="{ui:ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ui:ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8">
                    <StackPanel>

                        <!--  第一行：来源、类型、新建开关  -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="24" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="24" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <!--  来源  -->
                            <TextBlock
                                Grid.Column="0"
                                Margin="0,0,12,0"
                                VerticalAlignment="Center"
                                Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}"
                                Text="{x:Static properties:Resources.AddDisk_Source}" />

                            <ComboBox
                                Grid.Column="1"
                                HorizontalAlignment="Stretch"
                                SelectedValue="{Binding IsPhysicalSource, Mode=TwoWay}"
                                SelectedValuePath="Tag">
                                <ComboBoxItem Content="{x:Static properties:Resources.AddDisk_Source_VirtualFile}" Tag="{x:Static system:Boolean.FalseString}" />
                                <ComboBoxItem Content="{x:Static properties:Resources.AddDisk_Source_Physical}" Tag="{x:Static system:Boolean.TrueString}" />
                            </ComboBox>

                            <!--  类型  -->
                            <TextBlock
                                Grid.Column="3"
                                Margin="0,0,12,0"
                                VerticalAlignment="Center"
                                Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}"
                                Text="{x:Static properties:Resources.AddDisk_Type}" />

                            <ComboBox
                                Grid.Column="4"
                                HorizontalAlignment="Stretch"
                                SelectedValue="{Binding DeviceType, Mode=TwoWay}"
                                SelectedValuePath="Tag">
                                <ComboBoxItem Content="{x:Static properties:Resources.AddDisk_Type_HardDisk}" Tag="HardDisk" />
                                <ComboBoxItem Content="{x:Static properties:Resources.AddDisk_Type_OpticalDrive}" Tag="DvdDrive" />
                            </ComboBox>

                            <!--  新建开关 (仅虚拟文件显示)  -->
                            <StackPanel
                                Grid.Column="6"
                                VerticalAlignment="Center"
                                Orientation="Horizontal">
                                <StackPanel.Style>
                                    <Style TargetType="StackPanel">
                                        <Setter Property="Visibility" Value="Visible" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsPhysicalSource}" Value="True">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </StackPanel.Style>
                                <TextBlock
                                    Margin="0,0,12,0"
                                    VerticalAlignment="Center"
                                    Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}"
                                    Text="{x:Static properties:Resources.AddDisk_New}" />
                                <!--  重点：使用 TwoWay 绑定并立即更新，防止切换类型时状态丢失  -->
                                <ui:ToggleSwitch IsChecked="{Binding IsNewDisk, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                        </Grid>

                        <!--  虚拟文件路径选择 (IsPhysicalSource = False 且 NOT (New ISO from Directory))  -->
                        <StackPanel Margin="0,16,0,0">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsPhysicalSource}" Value="False">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <ui:TextBox
                                    VerticalAlignment="Center"
                                    PlaceholderText="{Binding FilePathPlaceholder}"
                                    Text="{Binding FilePath, UpdateSourceTrigger=PropertyChanged}" />
                                <ui:Button
                                    Grid.Column="1"
                                    Width="80"
                                    Margin="8,0,0,0"
                                    Command="{Binding BrowseFileCommand}"
                                    Content="{Binding BrowseButtonText}" />
                            </Grid>

                            <!--  新建虚拟硬盘参数 (仅 New=True 且 Type=HardDisk)  -->
                            <StackPanel Margin="0,16,0,0">
                                <StackPanel.Style>
                                    <Style TargetType="StackPanel">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <MultiDataTrigger>
                                                <MultiDataTrigger.Conditions>
                                                    <Condition Binding="{Binding IsNewDisk}" Value="True" />
                                                    <Condition Binding="{Binding DeviceType}" Value="HardDisk" />
                                                </MultiDataTrigger.Conditions>
                                                <Setter Property="Visibility" Value="Visible" />
                                            </MultiDataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </StackPanel.Style>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="12" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="12" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="12" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <!--  容量  -->
                                    <StackPanel Grid.Column="0">
                                        <TextBlock
                                            Margin="0,0,0,4"
                                            FontSize="12"
                                            Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}"
                                            Text="{x:Static properties:Resources.AddDisk_CapacityGB}" />
                                        <ComboBox
                                            HorizontalAlignment="Stretch"
                                            IsEditable="True"
                                            ItemsSource="{Binding NewDiskSizePresets}"
                                            Text="{Binding NewDiskSize, Mode=TwoWay}">
                                            <ComboBox.Style>
                                                <Style BasedOn="{StaticResource {x:Type ComboBox}}" TargetType="ComboBox">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding SelectedVhdType}" Value="Differencing">
                                                            <Setter Property="IsEnabled" Value="False" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </ComboBox.Style>
                                        </ComboBox>
                                    </StackPanel>

                                    <!--  磁盘类型  -->
                                    <StackPanel Grid.Column="2">
                                        <TextBlock
                                            Margin="0,0,0,4"
                                            FontSize="12"
                                            Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}"
                                            Text="{x:Static properties:Resources.AddDisk_DiskType}" />
                                        <ComboBox
                                            HorizontalAlignment="Stretch"
                                            SelectedValue="{Binding SelectedVhdType}"
                                            SelectedValuePath="Tag">
                                            <ComboBoxItem Content="{x:Static properties:Resources.AddDisk_VhdType_Dynamic}" Tag="Dynamic" />
                                            <ComboBoxItem Content="{x:Static properties:Resources.AddDisk_VhdType_Fixed}" Tag="Fixed" />
                                            <ComboBoxItem Content="{x:Static properties:Resources.AddDisk_VhdType_Differencing}" Tag="Differencing" />
                                        </ComboBox>
                                    </StackPanel>

                                    <!--  扇区格式  -->
                                    <StackPanel Grid.Column="4">
                                        <TextBlock
                                            Margin="0,0,0,4"
                                            FontSize="12"
                                            Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}"
                                            Text="{x:Static properties:Resources.AddDisk_SectorFormat}" />
                                        <ComboBox
                                            HorizontalAlignment="Stretch"
                                            SelectedValue="{Binding SectorFormat}"
                                            SelectedValuePath="Tag">
                                            <ComboBox.Style>
                                                <Style BasedOn="{StaticResource {x:Type ComboBox}}" TargetType="ComboBox">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding SelectedVhdType}" Value="Differencing">
                                                            <Setter Property="IsEnabled" Value="False" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </ComboBox.Style>
                                            <ComboBoxItem Content="{x:Static properties:Resources.Common_Default}" Tag="Default" />
                                            <ComboBoxItem Content="512n" Tag="512n" />
                                            <ComboBoxItem Content="512e" Tag="512e" />
                                            <ComboBoxItem Content="4Kn" Tag="4kn" />
                                        </ComboBox>
                                    </StackPanel>

                                    <!--  块大小  -->
                                    <StackPanel Grid.Column="6">
                                        <TextBlock
                                            Margin="0,0,0,4"
                                            FontSize="12"
                                            Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}"
                                            Text="{x:Static properties:Resources.AddDisk_BlockSize}" />
                                        <ComboBox
                                            HorizontalAlignment="Stretch"
                                            SelectedValue="{Binding BlockSize, Mode=TwoWay}"
                                            SelectedValuePath="Tag">
                                            <ComboBox.Style>
                                                <Style BasedOn="{StaticResource {x:Type ComboBox}}" TargetType="ComboBox">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding SelectedVhdType}" Value="Differencing">
                                                            <Setter Property="IsEnabled" Value="False" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </ComboBox.Style>
                                            <ComboBoxItem Content="{x:Static properties:Resources.Common_Default}" Tag="Default" />
                                            <ComboBoxItem Content="1 MB" Tag="1048576" />
                                            <ComboBoxItem Content="2 MB" Tag="2097152" />
                                            <ComboBoxItem Content="4 MB" Tag="4194304" />
                                            <ComboBoxItem Content="8 MB" Tag="8388608" />
                                            <ComboBoxItem Content="16 MB" Tag="16777216" />
                                            <ComboBoxItem Content="32 MB" Tag="33554432" />
                                            <ComboBoxItem Content="64 MB" Tag="67108864" />
                                            <ComboBoxItem Content="128 MB" Tag="134217728" />
                                            <ComboBoxItem Content="256 MB" Tag="268435456" />
                                        </ComboBox>
                                    </StackPanel>
                                </Grid>

                                <!--  差分盘父路径  -->
                                <Grid Margin="0,12,0,0">
                                    <Grid.Style>
                                        <Style TargetType="Grid">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedVhdType}" Value="Differencing">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Grid.Style>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <ui:TextBox
                                        VerticalAlignment="Center"
                                        PlaceholderText="{x:Static properties:Resources.AddDisk_Placeholder_ParentPath}"
                                        Text="{Binding ParentPath}" />
                                    <ui:Button
                                        Grid.Column="1"
                                        Width="80"
                                        Margin="8,0,0,0"
                                        Command="{Binding BrowseParentFileCommand}"
                                        Content="{x:Static properties:Resources.Common_Browse}" />
                                </Grid>
                            </StackPanel>
                        </StackPanel>

                        <!--  物理磁盘列表 (IsPhysicalSource = True)  -->
                        <!--  重点修复：使用 Converter 直接控制可见性，避免 Style Trigger 失效留白  -->
                        <StackPanel Visibility="{Binding IsPhysicalSource, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <TextBlock
                                Margin="0,24"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}"
                                Text="{x:Static properties:Resources.AddDisk_NoAvailablePhysical}"
                                Visibility="{Binding HostDisks.Count, Converter={StaticResource EqualityToVisibilityConverter}, ConverterParameter=0}" />

                            <ui:ListView
                                MaxHeight="200"
                                Margin="0,16,0,0"
                                Background="Transparent"
                                BorderThickness="0"
                                ItemsSource="{Binding HostDisks}"
                                SelectedItem="{Binding SelectedPhysicalDisk}">
                                <ui:ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="8,6">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <ui:FontIcon
                                                VerticalAlignment="Center"
                                                FontFamily="{StaticResource SegoeFluentIcons}"
                                                FontSize="24"
                                                Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}"
                                                Glyph="&#xEDA2;" />
                                            <StackPanel Grid.Column="1" Margin="16,0,0,0">
                                                <TextBlock
                                                    FontWeight="Medium"
                                                    Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}"
                                                    Text="{Binding FriendlyName}" />
                                                <StackPanel Margin="0,2,0,0" Orientation="Horizontal">
                                                    <TextBlock Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}" Text="{x:Static properties:Resources.Common_Disk}" />
                                                    <TextBlock
                                                        Margin="4,0,0,0"
                                                        Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}"
                                                        Text="{Binding Number}" />
                                                    <TextBlock
                                                        Margin="8,0"
                                                        Foreground="{ui:ThemeResource TextFillColorTertiaryBrush}"
                                                        Text=" | " />
                                                    <TextBlock Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}" Text="{Binding SizeGB, StringFormat='{}{0:F2} GB'}" />
                                                </StackPanel>
                                            </StackPanel>
                                        </Grid>
                                    </DataTemplate>
                                </ui:ListView.ItemTemplate>
                            </ui:ListView>
                        </StackPanel>

                    </StackPanel>
                </Border>

                <!--  底部操作栏  -->
                <Grid Margin="0,8,0,0">
                    <StackPanel
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        Orientation="Horizontal"
                        Visibility="{Binding SlotWarningVisibility}">
                        <ui:SymbolIcon
                            VerticalAlignment="Center"
                            Foreground="Red"
                            Symbol="Warning24" />
                        <TextBlock
                            MaxWidth="400"
                            Margin="8,0,0,0"
                            VerticalAlignment="Center"
                            FontSize="12"
                            Foreground="Red"
                            Text="{Binding SlotWarningMessage}"
                            TextWrapping="Wrap" />
                    </StackPanel>

                    <ui:Button
                        Width="120"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Appearance="Primary"
                        Command="{Binding ConfirmAddStorageCommand}"
                        Content="{x:Static properties:Resources.sure}"
                        IsEnabled="{Binding IsSlotValid}" />
                </Grid>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
