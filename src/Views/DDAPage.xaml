<Page
    x:Class="ExHyperV.Views.Pages.DDAPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="clr-namespace:ExHyperV.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:properties="clr-namespace:ExHyperV.Properties"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:vm="clr-namespace:ExHyperV.ViewModels"
    Title="DDAPage"
    d:DataContext="{d:DesignInstance vm:DDAPageViewModel,
                                     IsDesignTimeCreatable=True}"
    mc:Ignorable="d">

    <Page.DataContext>
        <vm:DDAPageViewModel />
    </Page.DataContext>

    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <converters:CommandParameterConverter x:Key="CommandParameterConverter" />
    </Page.Resources>

    <Grid>
        <StackPanel Margin="10,0,10,10">
            <ui:InfoBar
                Title="{x:Static properties:Resources.error}"
                Margin="0,5,0,0"
                IsClosable="False"
                IsOpen="{Binding ShowServerError}"
                Message="{x:Static properties:Resources.servererror}"
                Severity="Error" />

            <Grid Margin="0,5,0,0">
                <ui:Card Padding="10" BorderThickness="1">
                    <Grid>
                        <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                            <ui:FontIcon
                                FontFamily="{DynamicResource SegoeFluentIcons}"
                                FontSize="24"
                                Glyph="&#xF0B9;" />
                            <TextBlock
                                Margin="10,0,0,0"
                                VerticalAlignment="Center"
                                FontSize="16"
                                Text="{x:Static properties:Resources.Assignabledevices}" />
                        </StackPanel>
                        <ui:Button
                            HorizontalAlignment="Right"
                            Command="{Binding LoadDataCommand}"
                            Content="{x:Static properties:Resources.refresh}"
                            IsEnabled="{Binding IsUiEnabled}" />
                    </Grid>
                </ui:Card>
            </Grid>

            <ItemsControl Margin="0,0,0,0" ItemsSource="{Binding Devices}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <ui:CardExpander
                            Margin="20,5,0,0"
                            ContentPadding="6"
                            IsExpanded="False">
                            <ui:CardExpander.Icon>
                                <ui:FontIcon
                                    FontFamily="{DynamicResource SegoeFluentIcons}"
                                    FontSize="24"
                                    Glyph="{Binding IconGlyph}" />
                            </ui:CardExpander.Icon>
                            <ui:CardExpander.Header>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock
                                        Grid.Column="0"
                                        Margin="0,-2,0,0"
                                        VerticalAlignment="Center"
                                        FontSize="16"
                                        Text="{Binding FriendlyName}"
                                        TextTrimming="CharacterEllipsis"
                                        TextWrapping="NoWrap" />
                                    <ui:DropDownButton
                                        Grid.Column="1"
                                        Margin="10,0,5,0"
                                        Content="{Binding Status}"
                                        IsEnabled="{Binding DataContext.IsUiEnabled, RelativeSource={RelativeSource AncestorType=Page}}">
                                        <ui:DropDownButton.Flyout>
                                            <ContextMenu ItemsSource="{Binding AssignmentOptions}">
                                                <ContextMenu.ItemContainerStyle>
                                                    <Style TargetType="MenuItem">
                                                        <Setter Property="Header" Value="{Binding}" />
                                                        <Setter Property="Command" Value="{Binding DataContext.ChangeAssignmentCommand, RelativeSource={RelativeSource AncestorType=Page}}" />
                                                        <Setter Property="CommandParameter">
                                                            <Setter.Value>
                                                                <MultiBinding Converter="{StaticResource CommandParameterConverter}">
                                                                    <Binding Path="DataContext" RelativeSource="{RelativeSource AncestorType=ui:CardExpander}" />
                                                                    <Binding />
                                                                </MultiBinding>
                                                            </Setter.Value>
                                                        </Setter>
                                                    </Style>
                                                </ContextMenu.ItemContainerStyle>
                                            </ContextMenu>
                                        </ui:DropDownButton.Flyout>
                                    </ui:DropDownButton>
                                </Grid>
                            </ui:CardExpander.Header>
                            <StackPanel Margin="42,10,0,0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="125" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="32" />
                                        <RowDefinition Height="32" />
                                        <RowDefinition Height="32" />
                                        <RowDefinition Height="32" />
                                    </Grid.RowDefinitions>
                                    <TextBlock
                                        Grid.Row="0"
                                        Grid.Column="0"
                                        Margin="0,0,10,10"
                                        VerticalAlignment="Center"
                                        FontSize="16"
                                        Text="{x:Static properties:Resources.kind}" />
                                    <TextBlock
                                        Grid.Row="0"
                                        Grid.Column="1"
                                        Margin="0,0,10,10"
                                        VerticalAlignment="Center"
                                        FontSize="16"
                                        Text="{Binding ClassType}"
                                        TextTrimming="CharacterEllipsis"
                                        TextWrapping="NoWrap" />
                                    <TextBlock
                                        Grid.Row="1"
                                        Grid.Column="0"
                                        Margin="0,0,10,10"
                                        VerticalAlignment="Center"
                                        FontSize="16"
                                        Text="{x:Static properties:Resources.Instanceid}" />
                                    <TextBlock
                                        Grid.Row="1"
                                        Grid.Column="1"
                                        Margin="0,0,10,10"
                                        VerticalAlignment="Center"
                                        FontSize="16"
                                        Text="{Binding InstanceId}"
                                        TextTrimming="CharacterEllipsis"
                                        TextWrapping="NoWrap" />
                                    <TextBlock
                                        Grid.Row="2"
                                        Grid.Column="0"
                                        Margin="0,0,10,10"
                                        VerticalAlignment="Center"
                                        FontSize="16"
                                        Text="{x:Static properties:Resources.path}" />
                                    <TextBlock
                                        Grid.Row="2"
                                        Grid.Column="1"
                                        Margin="0,0,10,10"
                                        VerticalAlignment="Center"
                                        FontSize="16"
                                        Text="{Binding Path}"
                                        TextTrimming="CharacterEllipsis"
                                        TextWrapping="NoWrap" />
                                    <TextBlock
                                        Grid.Row="3"
                                        Grid.Column="0"
                                        Margin="0,0,10,10"
                                        VerticalAlignment="Center"
                                        FontSize="16"
                                        Text="{x:Static properties:Resources.manu}" />
                                    <TextBlock
                                        Grid.Row="3"
                                        Grid.Column="1"
                                        Margin="0,0,10,10"
                                        VerticalAlignment="Center"
                                        FontSize="16"
                                        Text="{Binding Vendor}"
                                        TextTrimming="CharacterEllipsis"
                                        TextWrapping="NoWrap" />
                                </Grid>
                            </StackPanel>
                        </ui:CardExpander>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>

        <ProgressBar
            Height="4"
            VerticalAlignment="Top"
            Panel.ZIndex="1"
            IsIndeterminate="True"
            Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}" />
    </Grid>
</Page>
