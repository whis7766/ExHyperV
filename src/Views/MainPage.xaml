<Page
    x:Class="ExHyperV.Views.Pages.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:ExHyperV.Views.Pages"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:properties="clr-namespace:ExHyperV.Properties"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:vm="clr-namespace:ExHyperV.ViewModels"
    Title="MainPage"
    d:DataContext="{d:DesignInstance Type=vm:MainPageViewModel,
                                     IsDesignTimeCreatable=True}"
    d:DesignHeight="800"
    d:DesignWidth="1000"
    mc:Ignorable="d">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <!--  0: 信息展示区  -->
            <RowDefinition Height="*" />
            <!--  1: 引导按钮区  -->
        </Grid.RowDefinitions>

        <!--  0. 信息展示区 (改为 VerticalAlignment="Top" 解决居中问题，移除加粗)  -->
        <Grid Grid.Row="0" Margin="0,5,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!--  系统信息卡片  -->
            <ui:CardControl
                Grid.Column="0"
                Margin="0,0,5,0"
                VerticalAlignment="Top">
                <ui:CardControl.Header>
                    <StackPanel Margin="5">
                        <StackPanel Margin="0,0,0,15" Orientation="Horizontal">
                            <ui:FontIcon
                                Margin="0,0,12,0"
                                FontFamily="{DynamicResource SegoeFluentIcons}"
                                FontSize="24"
                                Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}"
                                Glyph="" />
                            <TextBlock
                                VerticalAlignment="Center"
                                FontSize="18"
                                Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}"
                                Text="{x:Static properties:Resources.systeminfo}" />
                        </StackPanel>

                        <Grid Margin="38,0,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                            </Grid.RowDefinitions>

                            <TextBlock
                                Grid.Row="0"
                                VerticalAlignment="Center"
                                FontSize="16"
                                Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}"
                                Text="{x:Static properties:Resources.version}" />
                            <TextBlock
                                Grid.Row="1"
                                VerticalAlignment="Center"
                                FontSize="16"
                                Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}"
                                Text="{x:Static properties:Resources.arch}" />
                            <TextBlock
                                Grid.Row="2"
                                VerticalAlignment="Center"
                                FontSize="16"
                                Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}"
                                Text="{x:Static properties:Resources.model}" />
                            <TextBlock
                                Grid.Row="3"
                                VerticalAlignment="Center"
                                FontSize="16"
                                Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}"
                                Text="{x:Static properties:Resources.Memorycapacity}" />

                            <TextBlock
                                Grid.Row="0"
                                Grid.Column="1"
                                VerticalAlignment="Center"
                                FontSize="16"
                                Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}"
                                Text="{Binding Caption}"
                                TextTrimming="CharacterEllipsis" />
                            <TextBlock
                                Grid.Row="1"
                                Grid.Column="1"
                                VerticalAlignment="Center"
                                FontSize="16"
                                Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}"
                                Text="{Binding OSArchitecture}" />
                            <TextBlock
                                Grid.Row="2"
                                Grid.Column="1"
                                VerticalAlignment="Center"
                                FontSize="16"
                                Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}"
                                Text="{Binding CpuModel}"
                                TextTrimming="CharacterEllipsis" />
                            <TextBlock
                                Grid.Row="3"
                                Grid.Column="1"
                                VerticalAlignment="Center"
                                FontSize="16"
                                Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}"
                                Text="{Binding MemCap}" />
                        </Grid>
                    </StackPanel>
                </ui:CardControl.Header>
            </ui:CardControl>

        </Grid>

        <UniformGrid
            Grid.Row="1"
            VerticalAlignment="Top"
            Columns="2">

            <ui:CardAction
                Margin="0,5,5,5"
                Padding="15,20"
                Command="{Binding NavigateCommand}"
                CommandParameter="Host">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <ui:FontIcon
                        Grid.Column="0"
                        Margin="0,0,15,0"
                        FontFamily="{DynamicResource SegoeFluentIcons}"
                        FontSize="24"
                        Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}"
                        Glyph="&#xE737;" />
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock FontSize="16" Text="{x:Static properties:Resources.Menu_HostConfig}" />
                        <TextBlock
                            Margin="0,4,0,0"
                            FontSize="13"
                            Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}"
                            Text="{x:Static properties:Resources.Desc_HostConfig}" />
                    </StackPanel>
                </Grid>
            </ui:CardAction>

            <ui:CardAction
                Margin="5,5,0,5"
                Padding="15,20"
                Command="{Binding NavigateCommand}"
                CommandParameter="VM">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <ui:FontIcon
                        Grid.Column="0"
                        Margin="0,0,15,0"
                        FontFamily="{DynamicResource SegoeFluentIcons}"
                        FontSize="24"
                        Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}"
                        Glyph="&#xF5ED;" />
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock FontSize="16" Text="{x:Static properties:Resources.Menu_VMManagement}" />
                        <TextBlock
                            Margin="0,4,0,0"
                            FontSize="13"
                            Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}"
                            Text="{x:Static properties:Resources.Desc_VMManagement}" />
                    </StackPanel>
                </Grid>
            </ui:CardAction>

            <ui:CardAction
                Margin="0,5,5,5"
                Padding="15,20"
                Command="{Binding NavigateCommand}"
                CommandParameter="PCIe">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <ui:FontIcon
                        Grid.Column="0"
                        Margin="0,0,15,0"
                        FontFamily="{DynamicResource SegoeFluentIcons}"
                        FontSize="24"
                        Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}"
                        Glyph="&#xF0B9;" />
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock FontSize="16" Text="{x:Static properties:Resources.Menu_Pcie}" />
                        <TextBlock
                            Margin="0,4,0,0"
                            FontSize="13"
                            Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}"
                            Text="{x:Static properties:Resources.Desc_Pcie}" />
                    </StackPanel>
                </Grid>
            </ui:CardAction>


            <ui:CardAction
                Margin="5,5,0,5"
                Padding="15,20"
                Command="{Binding NavigateCommand}"
                CommandParameter="Network">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <ui:FontIcon
                        Grid.Column="0"
                        Margin="0,0,15,0"
                        FontFamily="{DynamicResource SegoeFluentIcons}"
                        FontSize="24"
                        Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}"
                        Glyph="&#xE774;" />
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock FontSize="16" Text="{x:Static properties:Resources.Menu_NetSwitch}" />
                        <TextBlock
                            Margin="0,4,0,0"
                            FontSize="13"
                            Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}"
                            Text="{x:Static properties:Resources.Desc_NetSwitch}" />
                    </StackPanel>
                </Grid>
            </ui:CardAction>

            <!-- <ui:CardAction Margin="0,5,5,5" Padding="15,20" Command="{Binding NavigateCommand}" CommandParameter="USB">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <ui:FontIcon Grid.Column="0" FontFamily="{DynamicResource SegoeFluentIcons}" Glyph="&#xE88E;" FontSize="24" Margin="0,0,15,0" Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}"/>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="{x:Static properties:Resources.MainWindow_1}" Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}" FontSize="16"/>
                        <TextBlock Text="{x:Static properties:Resources.MainPage_2}" FontSize="13" Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}" Margin="0,4,0,0"/>
                    </StackPanel>
                </Grid>
            </ui:CardAction>-->


        </UniformGrid>
    </Grid>
</Page>
