<Page
    x:Class="ExHyperV.Views.Pages.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:ExHyperV.Views.Pages"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:properties="clr-namespace:ExHyperV.Properties"
    xmlns:vm="clr-namespace:ExHyperV.ViewModels"
    mc:Ignorable="d"
    d:DataContext="{d:DesignInstance Type=vm:MainPageViewModel, IsDesignTimeCreatable=True}"
    Title="MainPage"
    d:DesignHeight="800"
    d:DesignWidth="1000">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- 0: Banner -->
            <RowDefinition Height="Auto"/>
            <!-- 1: 信息展示区 -->
            <RowDefinition Height="*"/>
            <!-- 2: 引导按钮区 -->
        </Grid.RowDefinitions>

        <!-- 1. Banner 区 (移除加粗，恢复圆角) -->
        <Grid Grid.Row="0" Margin="0,0,0,10">
            <!-- 背景图片 -->
            <ui:Image CornerRadius="15" Stretch="Uniform" Source="pack://application:,,,/Assets/banner.png"/>

            <!-- 左侧标题文字 -->
            <StackPanel VerticalAlignment="Center" Margin="30,5,0,-25">
                <TextBlock Text="ExHyperV" 
                   FontSize="42" 
                   Foreground="White"
                   FontFamily="pack://application:,,,/Assets/fonts/#Audiowide" 
                   />
                <TextBlock Text="{x:Static properties:Resources.exhyperv}"
                   
                   
                   FontSize="18" 
                   Foreground="#CCFFFFFF" 
                   Margin="5,10,0,0"/>
            </StackPanel>

            <!-- 右下角版本号 (新增) -->
            <TextBlock Text="{Binding AppVersion}"
               HorizontalAlignment="Right"
               VerticalAlignment="Bottom"
               Margin="0,0,25,15"
               Foreground="#99FFFFFF"
               FontSize="14"
               FontWeight="SemiBold"/>
        </Grid>

        <!-- 2. 信息展示区 (改为 VerticalAlignment="Top" 解决居中问题，移除加粗) -->
        <Grid Grid.Row="1" Margin="0,5,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 系统信息卡片 -->
            <ui:CardControl Grid.Column="0" Margin="0,0,5,0" VerticalAlignment="Top">
                <ui:CardControl.Header>
                    <StackPanel Margin="5">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                            <ui:FontIcon FontFamily="{DynamicResource SegoeFluentIcons}" Glyph="" FontSize="24" Margin="0,0,12,0" Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}"/>
                            <TextBlock Text="{x:Static properties:Resources.systeminfo}" FontSize="18" VerticalAlignment="Center" Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}"/>
                        </StackPanel>

                        <Grid Margin="38,0,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="35"/>
                                <RowDefinition Height="35"/>
                                <RowDefinition Height="35"/>
                                <RowDefinition Height="35"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Text="{x:Static properties:Resources.version}" FontSize="16" VerticalAlignment="Center" Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}"/>
                            <TextBlock Grid.Row="1" Text="{x:Static properties:Resources.arch}" FontSize="16" VerticalAlignment="Center" Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}"/>
                            <TextBlock Grid.Row="2" Text="{x:Static properties:Resources.model}" FontSize="16" VerticalAlignment="Center" Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}"/>
                            <TextBlock Grid.Row="3" Text="{x:Static properties:Resources.Memorycapacity}" FontSize="16" VerticalAlignment="Center" Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}"/>

                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Caption}" FontSize="16" VerticalAlignment="Center" Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}" TextTrimming="CharacterEllipsis"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding OSArchitecture}" FontSize="16" VerticalAlignment="Center" Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding CpuModel}" FontSize="16" VerticalAlignment="Center" Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}" TextTrimming="CharacterEllipsis"/>
                            <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding MemCap}" FontSize="16" VerticalAlignment="Center" Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}"/>
                        </Grid>
                    </StackPanel>
                </ui:CardControl.Header>
            </ui:CardControl>

        </Grid>

        <UniformGrid Grid.Row="2" Columns="2" VerticalAlignment="Top">

            <ui:CardAction Margin="0,5,5,5" Padding="15,20" Command="{Binding NavigateCommand}" CommandParameter="Host">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <ui:FontIcon Grid.Column="0" FontFamily="{DynamicResource SegoeFluentIcons}" Glyph="&#xE737;" FontSize="24" Margin="0,0,15,0" Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}"/>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="{x:Static properties:Resources.Menu_HostConfig}" FontSize="16"/>
                        <TextBlock Text="{x:Static properties:Resources.Desc_HostConfig}" FontSize="13" Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}" Margin="0,4,0,0"/>
                    </StackPanel>
                </Grid>
            </ui:CardAction>

            <ui:CardAction Margin="5,5,0,5" Padding="15,20" Command="{Binding NavigateCommand}" CommandParameter="VM">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <ui:FontIcon Grid.Column="0" FontFamily="{DynamicResource SegoeFluentIcons}" Glyph="&#xF5ED;" FontSize="24" Margin="0,0,15,0" Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}"/>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="{x:Static properties:Resources.Menu_VMManagement}" FontSize="16"/>
                        <TextBlock Text="{x:Static properties:Resources.Desc_VMManagement}" FontSize="13" Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}" Margin="0,4,0,0"/>
                    </StackPanel>
                </Grid>
            </ui:CardAction>

            <ui:CardAction Margin="0,5,5,5" Padding="15,20" Command="{Binding NavigateCommand}" CommandParameter="PCIe">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <ui:FontIcon Grid.Column="0" FontFamily="{DynamicResource SegoeFluentIcons}" Glyph="&#xF0B9;" FontSize="24" Margin="0,0,15,0" Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}"/>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="{x:Static properties:Resources.Menu_Pcie}" FontSize="16"/>
                        <TextBlock Text="{x:Static properties:Resources.Desc_Pcie}" FontSize="13" Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}" Margin="0,4,0,0"/>
                    </StackPanel>
                </Grid>
            </ui:CardAction>


            <ui:CardAction Margin="5,5,0,5" Padding="15,20" Command="{Binding NavigateCommand}" CommandParameter="Network">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <ui:FontIcon Grid.Column="0" FontFamily="{DynamicResource SegoeFluentIcons}" Glyph="&#xE774;" FontSize="24" Margin="0,0,15,0" Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}"/>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="{x:Static properties:Resources.Menu_NetSwitch}" FontSize="16"/>
                        <TextBlock Text="{x:Static properties:Resources.Desc_NetSwitch}" FontSize="13" Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}" Margin="0,4,0,0"/>
                    </StackPanel>
                </Grid>
            </ui:CardAction>

            <!-- <ui:CardAction Margin="0,5,5,5" Padding="15,20" Command="{Binding NavigateCommand}" CommandParameter="USB">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <ui:FontIcon Grid.Column="0" FontFamily="{DynamicResource SegoeFluentIcons}" Glyph="&#xE88E;" FontSize="24" Margin="0,0,15,0" Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}"/>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="{x:Static properties:Resources.MainWindow_1}" Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}" FontSize="16"/>
                        <TextBlock Text="{x:Static properties:Resources.MainPage_2}" FontSize="13" Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}" Margin="0,4,0,0"/>
                    </StackPanel>
                </Grid>
            </ui:CardAction> -->


        </UniformGrid>
    </Grid>
</Page>